# Environment Variables Example
# Copy this file to .env and fill in your actual values.
# NEVER commit your real .env file to version control.

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ── MongoDB ───────────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/ai-resume-reviewer
# Atlas:  mongodb+srv://<user>:<password>@cluster.mongodb.net/ai-resume-reviewer
MONGODB_URI=mongodb://localhost:27017/ai-resume-reviewer

# Test database (used by Jest — isolated from development data)
MONGODB_URI_TEST=mongodb://localhost:27017/ai-resume-reviewer-test

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4
MAX_TOKENS=2000

# ── File Upload ───────────────────────────────────────────────────────────────
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=application/pdf,text/plain

# ── Rate Limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=10